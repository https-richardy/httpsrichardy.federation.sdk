<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>HttpsRichardy.Federation.Sdk</PackageId>
    <Description>SDK for consuming the federation webapi and managing authentication and authorization.</Description>
    <PackageTags>identity;federation;sdk;jwt;oauth</PackageTags>
    <RepositoryUrl>https://github.com/https-richardy/httpsrichardy.federation.sdk.dotnet</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/https-richardy/httpsrichardy.federation.sdk.dotnet</PackageProjectUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.8" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.8" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="9.0.8" />
    <PackageReference Include="HttpsRichardy.Federation.Sdk.Contracts" Version="1.0.2" />
  </ItemGroup>

</Project>
